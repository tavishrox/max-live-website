rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null && request.auth.uid == "05378337030731377140";
    }

    match /artifacts/{appId}/public/data/blogPosts/{postId} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
